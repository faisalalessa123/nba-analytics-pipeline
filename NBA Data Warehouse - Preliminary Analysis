nced = []\n","all_playoff_defense = []\n","all_playoff_team = []\n","\n","for season in SEASONS:\n","    print(f\"Fetching {season} playoffs...\")\n","\n","    # Pull basic per-game playoff stats: points, assists, rebounds, FG%, 3P%, FT%, etc.\n","    df = fetch_with_retry(leaguedashplayerstats.LeagueDashPlayerStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Base\",\n","        per_mode_detailed=\"PerGame\",\n","        season_type_all_star=\"Playoffs\",  # Switch from Regular Season to Playoffs\n","    )\n","    df[\"SEASON\"] = season\n","    all_playoff_traditional.append(df)\n","    time.sleep(3)\n","\n","    # Pull advanced playoff metrics: PER, TS%, BPM, VORP, Win Shares, +/-, USG%, etc.\n","    df = fetch_with_retry(leaguedashplayerstats.LeagueDashPlayerStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Advanced\",\n","        per_mode_detailed=\"PerGame\",\n","        season_type_all_star=\"Playoffs\",\n","    )\n","    df[\"SEASON\"] = season\n","    all_playoff_advanced.append(df)\n","    time.sleep(3)\n","\n","    # Pull defensive playoff stats: opponent FG%, defensive rebounds, steals, blocks, etc.\n","    df = fetch_with_retry(leaguedashplayerstats.LeagueDashPlayerStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Defense\",\n","        per_mode_detailed=\"PerGame\",\n","        season_type_all_star=\"Playoffs\",\n","    )\n","    df[\"SEASON\"] = season\n","    all_playoff_defense.append(df)\n","    time.sleep(3)\n","\n","    # Pull team-level advanced playoff stats: offensive/defensive/net rating, pace, etc.\n","    df = fetch_with_retry(leaguedashteamstats.LeagueDashTeamStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Advanced\",\n","        season_type_all_star=\"Playoffs\",\n","    )\n","    df[\"SEASON\"] = season\n","    all_playoff_team.append(df)\n","    time.sleep(3)\n","\n","# Combine all seasons into single DataFrames and save as CSVs\n","pd.concat(all_playoff_traditional).to_csv(\"playoff_traditional.csv\", index=False)\n","pd.concat(all_playoff_advanced).to_csv(\"playoff_advanced.csv\", index=False)\n","pd.concat(all_playoff_defense).to_csv(\"playoff_defense.csv\", index=False)\n","pd.concat(all_playoff_team).to_csv(\"playoff_team.csv\", index=False)\n","\n","print(\"Done! playoff_traditional.csv, playoff_advanced.csv, playoff_defense.csv, playoff_team.csv saved.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Ju6oYtlYj212","executionInfo":{"status":"ok","timestamp":1775701931017,"user_tz":420,"elapsed":49141,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"8e3db4ad-1e7b-4313-94f7-baa95c3f0a18"},"execution_count":16,"outputs":[{"output_type":"stream","name":"stdout","text":["Fetching 2021-22 playoffs...\n","Fetching 2022-23 playoffs...\n","Fetching 2023-24 playoffs...\n","Fetching 2024-25 playoffs...\n","Done! playoff_traditional.csv, playoff_advanced.csv, playoff_defense.csv, playoff_team.csv saved.\n"]}]},{"cell_type":"code","source":["from google.colab import files\n","\n","# Download player bios, hustle stats, shooting splits, and all playoff CSVs\n","files.download(\"player_bios.csv\")\n","files.download(\"player_hustle.csv\")\n","files.download(\"player_shooting.csv\")\n","files.download(\"playoff_traditional.csv\")\n","files.download(\"playoff_advanced.csv\")\n","files.download(\"playoff_defense.csv\")\n","files.download(\"playoff_team.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":17},"id":"6jnPLeQjkzsS","executionInfo":{"status":"ok","timestamp":1775701931140,"user_tz":420,"elapsed":99,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"74beeb7a-d264-4dca-bb6f-c83bb4ec02b8"},"execution_count":17,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, fi