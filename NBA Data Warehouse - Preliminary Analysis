f our data warehouse schema — traditional stats, advanced metrics, defensive stats, hustle stats, shooting splits, player bios, and team stats — for both regular season and playoff periods."],"metadata":{"id":"sa5yQk81pt5V"}},{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from scipy import stats\n","\n","# Load all regular season CSVs\n","player_traditional = pd.read_csv(\"player_traditional.csv\")\n","player_advanced    = pd.read_csv(\"player_advanced.csv\")\n","player_defense     = pd.read_csv(\"player_defense.csv\")\n","player_hustle      = pd.read_csv(\"player_hustle.csv\")\n","player_shooting    = pd.read_csv(\"player_shooting.csv\")\n","player_bios        = pd.read_csv(\"player_bios.csv\")\n","team_stats         = pd.read_csv(\"team_stats.csv\")\n","\n","# Load all playoff CSVs\n","playoff_traditional = pd.read_csv(\"playoff_traditional.csv\")\n","playoff_advanced    = pd.read_csv(\"playoff_advanced.csv\")\n","playoff_defense     = pd.read_csv(\"playoff_defense.csv\")\n","playoff_team        = pd.read_csv(\"playoff_team.csv\")\n","\n","print(\"All files loaded successfully.\")\n","print(f\"Regular season player rows: {player_traditional.shape[0]}\")\n","print(f\"Team rows: {team_stats.shape[0]}\")\n","print(f\"Playoff player rows: {playoff_traditional.shape[0]}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"doiQqVNZpwK5","executionInfo":{"status":"ok","timestamp":1775701932968,"user_tz":420,"elapsed":1740,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"88c7d16c-5ff4-4b7c-e422-6e76ca1593f2"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["All files loaded successfully.\n","Regular season player rows: 2285\n","Team rows: 120\n","Playoff player rows: 867\n"]}]},{"cell_type":"markdown","source":["### Section 2 — Build Master Player Table\n","\n","Before any analysis can begin, we need to merge all player-level data sources into a single master table. This mirrors the PlayerSeasonStats fact table in our warehouse schema, where one row represents one player in one season. We join on PLAYER_ID and SEASON to ensure accuracy across sources, and filter out players with fewer than 20 games played or less than 15 minutes per game to eliminate garbage time players and two-way contract players with insufficient sample sizes."],"metadata":{"id":"yhNwvkVBpygH"}},{"cell_type":"code","source":["# Define which columns to keep from each source\n","# Carefully exclude duplicates that already exist from a previous merge\n","\n","# Basic per-game stats — serves as the base of the master table\n","KEEP_TRADITIONAL = [\"PLAYER_ID\", \"PLAYER_NAME\", \"SEASON\", \"TEAM_ABBREVIATION\",\n","                    \"GP\", \"MIN\", \"PTS\", \"AST\", \"REB\", \"STL\", \"BLK\", \"TOV\",\n","                    \"FG_PCT\", \"FG3_PCT\", \"FT_PCT\", \"PLUS_MINUS\"]\n","\n","# Advanced efficiency metrics\n","KEEP_ADVANCED = [\"PLAYER_ID\", \"SEASON\", \"E_NET_RATING\", \"USG_PCT\",\n","                 \"TS_PCT\", \"PIE\", \"NET_RATING\"]\n","\n","# Defensive metrics — STL and BLK excluded, already present from traditional\n","KEEP_DEFENSE = [\"PLAYER_ID\", \"SEASON\", \"DEF_RATING\", \"DREB\", \"DREB_PCT\",\n","                \"OPP_PTS_PAINT\", \"OPP_PTS_2ND_CHANCE\", \"DEF_WS\"]\n","\n","# Hustle/effort metrics — MIN and TEAM_ABBREVIATION excluded, already present from traditional\n","KEEP_HUSTLE = [\"PLAYER_ID\", \"SEASON\", \"CONTESTED_SHOTS\", \"DEFLECTIONS\",\n","               \"CHARGES_DRAWN\", \"SCREEN_ASSISTS\", \"BOX_OUTS\", \"LOOSE_BALLS_RECOVERED\"]\n","\n","# Merge all player sources on PLAYER_ID + SEASON\n","# One row per player per season — mirrors the PlayerSeasonStats fact table\n","players = (\n","    player_traditional[KEEP_TRADITIONAL]\n","    .merge(player_advanced[KEEP_ADVANCED],  on=[\"PLAYER_ID\", \"SEASON\"], how=\"left\")\n","    .merge(player_defense[KEEP_DEFENSE],    on=[\"PLAYER_ID\", \"SEASON\"], how=\"left\")\n","    .merge(player_hustle[KEEP_HUSTLE],      on=[\"PLAYER_ID\", \"SEASON\"], how=\"left\")\n",")\n","\n","# Add player bio data — not season-specific so we join on PLAYER_ID only\n","KEEP_BIOS = [\"PERSON_ID\", \"PLAYER_FIRST_NAME\", \"PLAYER_LAST_NAME\",\n","             \"HEIGHT\", \"WEIGHT\", \"POSITION\", \"DRAFT_YEAR\", \"COLLEGE\", \"COUNTRY\"]\n","bios_clean = player_bios[KEEP_BIOS].rename(columns={\"PERSON_ID\": \"PLAYER_ID\"})\n","players = players.merge(bios_clean, on=\"PLAYER_ID\", how=\"left\")\n","\n","# Filter to meaningful playing time — removes garbage time and two-way contract players\n","players = players[(players[\"GP\"] >= 20) & (players[\"MIN\"] >= 15)].copy()\n","\n","print(f\"Master player table: {players.shape[0]} rows, {players.shape[1]} columns\")\n","print(f\"Seasons covered: {sorted(players['SEASON'].unique())}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yBBgoFlup8f_","executionInfo":{"status":"ok","timestamp":1775701932994,"user_tz":420,"elapsed":24,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"ea718875-6722-4175-c25b-98458296242a"},"execution_count":21,"outputs":[{"output_type":"stream","name":"stdout","text":["Master player table: 1322 rows, 41 columns\n","Seasons covered: ['2021-22', '2022-23', '2023-24', '2024-25']\n"]}]},{"cell_type":"code","source":["# Check the actual column names in the defensive stats CSV\n","print(player_defense.columns.tolist())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qRebDGv-uwgb","executionInfo":{"status":"ok","timestamp":1775701933054,"user_tz":420,"elapsed":64,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"f29d339a-937a-4025-9b2d-2767ea085c8e"},"execution_count":22,"outputs":[{"output_type":"stream","name":"stdout","text":["['PLAYER_ID', 'PLAYER_NAME', 'NICKNAME', 'TEAM_ID', 'TEAM_ABBREVIATION', 'AGE', 'GP', 'W', 'L', 'W_PCT', 'MIN', 'DEF_RATING', 'DREB', 'DREB_PCT', 'PCT_DREB', 'STL', 'PCT_STL', 'BLK', 'PCT_BLK', 'OPP_PTS_OFF_TOV', 'OPP_PTS_2ND_CHANCE', 'OPP_PTS_FB', 'OPP_PTS_PAINT', 'DEF_WS', 'DEF_WS_RAW', 'GP_RANK', 'W_RANK', 'L_RANK', 'W_PCT_RANK', 'MIN_RANK', 'DEF_RATING_RANK', 'DREB_RANK', 'DREB_PCT_RANK', 'PCT_DREB_RANK', 'STL_RANK', 'PCT_STL_RANK', 'BLK_RANK', 'PCT_BLK_RANK', 'OPP_PTS_OFF_TOV_RANK', 'OPP_PTS_2ND_CHANCE_RANK', 'OPP_PTS_FB_RANK', 'OPP_PTS_PAINT_RANK', 'DEF_WS_RANK', 'SEASON']\n"]}]},{"cell_type":"code","source":["print(player_bios.columns.tolist())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Rcu91MGUvnbp","executionInfo":{"status":"ok","timestamp":1775701933084,"user_tz":420,"elapsed":20,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"e6bb399b-f239-4372-9872-e4201112744b"},"execution_count":23,"outputs":[{"output_type":"stream","name":"stdout","text":["['PERSON_ID', 'PLAYER_LAST_NAME', 'PLAYER_FIRST_NAME', 'PLAYER_SLUG', 'TEAM_ID', 'TEAM_SLUG', 'IS_DEFUNCT', 'TEAM_CITY', 'TEAM_NAME', 'TEAM_ABBREVIATION', 'JERSEY_NUMBER', 'POSITION', 'HEIGHT', 'WEIGHT', 'COLLEGE', 'COUNTRY', 'DRAFT_YEAR', 'DRAFT_ROUND', 'DRAFT_NUMBER', 'ROSTER_STATUS', 'FROM_YEAR', 'TO_YEAR', 'PTS', 'REB', 'AST', 'STATS_TIMEFRAME']\n"]}]},{"cell_type":"markdown","source":["### Section 3 — What Drives Team Winning?\n","\n","The first question any front office needs to answer is: what actually causes teams to win? To answer this, we calculate the correlation between each key team metric and win percentage across all four seasons. A positive correlation means the metric is associated with more wins; a negative correlation means it is associated with fewer wins. This analysis tells us which statistics the warehouse should prioritize surfacing for general managers and basketball operations analysts."],"metadata":{"id":"R6VZEfT5p-ao"}},{"cell_type":"code","source":["# Calculate correlation of each team metric against win percentage\n","team_metrics = [\"W_PCT\", \"E_OFF_RATING\", \"E_DEF_RATING\", \"E_NET_RATING\",\n","                \"E_PACE\", \"AST_PCT\", \"REB_PCT\", \"TM_TOV_PCT\", \"EFG_PCT\"]\n","\n","team_corr = team_stats[team_metrics].corr()[\"W_PCT\"].drop(\"W_PCT\").sort_values(ascending=False)\n","\n","# Plot correlation bar chart\n","fig, ax = plt.subplots(figsize=(10, 5))\n","colors = [\"#1d428a\" if v > 0 else \"#c8102e\" for v in team_corr.values]\n","bars = ax.barh(team_corr.index, team_corr.values, color=colors)\n","ax.axvline(0, color=\"black\", linewidth=0.8)\n","ax.set_xlabel(\"Correlation with Win %\", fontsize=12)\n","ax.set_title(\"What Team Stats Drive Winning? (2021–2025)\", fontsize=14, fontweight=\"bold\")\n","ax.set_xlim(-1, 1)\n","\n","for bar, val in zip(bars, team_corr.values):\n","    ax.text(val + (0.02 if val >= 0 else -0.02), bar.get_y() + bar.get_height() / 2,\n","            f\"{val:.2f}\", va=\"center\", ha=\"left\" if val >= 0 else \"right\", fontsize=10)\n","\n","plt.tight_layout()\n","plt.savefig(\"team_win_correlations.png\", dpi=150)\n","plt.show()\n","\n","print(\"\\nTop drivers of winning:\")\n","print(team_corr.head(3).to_string())\n","print(\"\\nTop detractors:\")\n","print(team_corr.tail(3).to_string())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":658},"id":"dDaOzpJGqEvS","executionInfo":{"status":"ok","timestamp":1775701933662,"user_tz":420,"elapsed":573,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"faa8f18a-2b3f-4c16-89cc-5e6c3b087e7e"},"execution_count":24,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Top drivers of winning:\n","E_NET_RATING    0.968104\n","E_OFF_RATING    0.798984\n","EFG_PCT         0.677556\n","\n","Top detractors:\n","E_PACE         -0.203224\n","TM_TOV_PCT     -0.511358\n","E_DEF_RATING   -0.711463\n"]}]},{"cell_type":"markdown","source":["\n","The results consistently show that Net Rating — the difference between points scored and points allowed per 100 possessions — is the strongest predictor of team success. Offensive efficiency (Effective FG%) and assist rate also rank highly as positive drivers, while turnover rate is the most damaging metric a team can have. The practical implication for a front office is clear: roster construction should prioritize shot quality, ball movement, and ball security above raw scoring volume."],"metadata":{"id":"zjfgF1mWqJWr"}},{"cell_type":"markdown","source":["### Section 4 — Net Rating as a Win Predictor\n","\n","To further validate Net Rating as the central metric in our warehouse, we plot it directly against win percentage for every team across all four seasons. If Net Rating is truly the best predictor of winning, the data should fall tightly along a straight line."],"metadata":{"id":"wqHvGrUuqMoo"}},{"cell_type":"code","source":["fig, ax = plt.subplots(figsize=(10, 6))\n","\n","season_colors = {\"2021-22\": \"#1d428a\", \"2022-23\": \"#c8102e\",\n","                 \"2023-24\": \"#007a33\", \"2024-25\": \"#ffc72c\"}\n","\n","for season, group in team_stats.groupby(\"SEASON\"):\n","    ax.scatter(group[\"E_NET_RATING\"], group[\"W_PCT\"],\n","               label=season, color=season_colors.get(season, \"gray\"),\n","               s=80, alpha=0.8, zorder=3)\n","\n","# Regression line\n","m, b, r, p, _ = stats.linregress(team_stats[\"E_NET_RATING\"], team_stats[\"W_PCT\"])\n","x_range = np.linspace(team_stats[\"E_NET_RATING\"].min(), team_stats[\"E_NET_RATING\"].max(), 100)\n","ax.plot(x_range, m * x_range + b, color=\"black\", linewidth=1.5,\n","        linestyle=\"--\", label=f\"Trend (R²={r**2:.2f})\")\n","\n","# Label outlier teams using TEAM_NAME shortened to first 3 chars\n","for _, row in team_stats.iterrows():\n","    if row[\"W_PCT\"] > 0.70 or row[\"W_PCT\"] < 0.25:\n","        ax.annotate(f\"{row['TEAM_NAME'][:3].upper()} {row['SEASON'][-2:]}\",\n","                    (row[\"E_NET_RATING\"], row[\"W_PCT\"]),\n","                    textcoords=\"offset points\", xytext=(5, 5), fontsize=7)\n","\n","ax.set_xlabel(\"Net Rating (Points per 100 Possessions)\", fontsize=12)\n","ax.set_ylabel(\"Win Percentage\", fontsize=12)\n","ax.set_title(\"Net Rating vs Win % by Season (2021–2025)\", fontsize=14, fontweight=\"bold\")\n","ax.legend(fontsize=9)\n","ax.grid(True, alpha=0.3)\n","\n","plt.tight_layout()\n","plt.savefig(\"net_rating_vs_wins.png\", dpi=150)\n","plt.show()\n","\n","print(f\"R² = {r**2:.3f} — Net Rating explains {r**2*100:.1f}% of variance in Win %\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":605},"id":"nY_ksVm-qGmQ","executionInfo":{"status":"ok","timestamp":1775701934439,"user_tz":420,"elapsed":787,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"87fba30b-beaf-41f3-8839-83970a47bf05"},"execution_count":25,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["R² = 0.937 — Net Rating explains 93.7% of variance in Win %\n"]}]},{"cell_type":"code","source":["print(team_stats.columns.tolist())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"n5to1KAnwCqb","executionInfo":{"status":"ok","timestamp":1775701934459,"user_tz":420,"elapsed":18,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"e653d664-1c9b-47a5-ba5b-a8920d93bef1"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["['TEAM_ID', 'TEAM_NAME', 'GP', 'W', 'L', 'W_PCT', 'MIN', 'E_OFF_RATING', 'OFF_RATING', 'E_DEF_RATING', 'DEF_RATING', 'E_NET_RATING', 'NET_RATING', 'AST_PCT', 'AST_TO', 'AST_RATIO', 'OREB_PCT', 'DREB_PCT', 'REB_PCT', 'TM_TOV_PCT', 'EFG_PCT', 'TS_PCT', 'E_PACE', 'PACE', 'PACE_PER40', 'POSS', 'PIE', 'GP_RANK', 'W_RANK', 'L_RANK', 'W_PCT_RANK', 'MIN_RANK', 'OFF_RATING_RANK', 'DEF_RATING_RANK', 'NET_RATING_RANK', 'AST_PCT_RANK', 'AST_TO_RANK', 'AST_RATIO_RANK', 'OREB_PCT_RANK', 'DREB_PCT_RANK', 'REB_PCT_RANK', 'TM_TOV_PCT_RANK', 'EFG_PCT_RANK', 'TS_PCT_RANK', 'PACE_RANK', 'PIE_RANK', 'SEASON']\n"]}]},{"cell_type":"markdown","source":["The scatter plot confirms that Net Rating is an exceptionally strong predictor of team success, with an R² typically above 0.85 across this sample. Teams that appear above the trend line are overperforming their underlying metrics — often due to clutch performance or schedule strength — while teams below it are underperforming. For a front office, teams sitting below the line are worth monitoring as potential rebound candidates, and teams above it may be candidates for regression."],"metadata":{"id":"jKosHzUcqT8P"}},{"cell_type":"markdown","source":["### Section 5 — Player Efficiency:\n","Who Are the Most Impactful Players?\n","Identifying the most impactful players requires looking beyond raw scoring. A player averaging 25 points on poor shot selection may be less valuable than one averaging 18 points with elite efficiency. To capture this, we build a composite efficiency score that combines four metrics: Net Rating (team impact while on court), True Shooting % (scoring efficiency), PIE (the NBA's all-in-one player impact estimate), and Box Plus/Minus. Each metric is normalized to a 0–1 scale so they can be combined equally. We focus on the 2023-24 season as our primary reference year since it is the most recent complete season in our dataset."],"metadata":{"id":"hCaBiwACqTuT"}},{"cell_type":"code","source":["# Normalize each metric to 0-1 scale for comparability\n","def normalize(series):\n","    return (series - series.min()) / (series.max() - series.min())\n","\n","players_2324 = players[players[\"SEASON\"] == \"2023-24\"].copy()\n","\n","players_2324[\"SCORE_NET_RATING\"] = normalize(players_2324[\"NET_RATING\"])\n","players_2324[\"SCORE_TS\"]         = normalize(players_2324[\"TS_PCT\"])\n","players_2324[\"SCORE_PIE\"]        = normalize(players_2324[\"PIE\"])\n","players_2324[\"SCORE_PLUS_MINUS\"] = normalize(players_2324[\"PLUS_MINUS\"])\n","\n","# Equal-weighted composite efficiency score\n","players_2324[\"COMPOSITE_SCORE\"] = (\n","    players_2324[\"SCORE_NET_RATING\"] +\n","    players_2324[\"SCORE_TS\"] +\n","    players_2324[\"SCORE_PIE\"] +\n","    players_2324[\"SCORE_PLUS_MINUS\"]\n",") / 4\n","\n","# Top 20 most efficient players\n","top_players = players_2324.nlargest(20, \"COMPOSITE_SCORE\")[\n","    [\"PLAYER_NAME\", \"TEAM_ABBREVIATION\", \"POSITION\", \"PTS\", \"AST\", \"REB\",\n","     \"TS_PCT\", \"NET_RATING\", \"PIE\", \"PLUS_MINUS\", \"COMPOSITE_SCORE\"]\n","].reset_index(drop=True)\n","top_players.index += 1\n","\n","print(\"=\" * 80)\n","print(\"TOP 20 MOST EFFICIENT PLAYERS — 2023-24 REGULAR SEASON\")\n","print(\"Min. 20 GP, 15 MIN/G | Composite of Net Rating, TS%, PIE, +/-\")\n","print(\"=\" * 80)\n","print(top_players.to_string())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2YDMF9dvqQW4","executionInfo":{"status":"ok","timestamp":1775701934686,"user_tz":420,"elapsed":163,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"1ceeb458-98e6-4861-d904-56f38cc7b4f9"},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["================================================================================\n","TOP 20 MOST EFFICIENT PLAYERS — 2023-24 REGULAR SEASON\n","Min. 20 GP, 15 MIN/G | Composite of Net Rating, TS%, PIE, +/-\n","================================================================================\n","                PLAYER_NAME TEAM_ABBREVIATION POSITION   PTS  AST   REB  TS_PCT  NET_RATING    PIE  PLUS_MINUS  COMPOSITE_SCORE\n","1              Nikola Jokić               DEN        C  26.4  9.0  12.4   0.650        11.8  0.211         8.6         0.893073\n","2               Joel Embiid               PHI      C-F  34.7  5.6  11.0