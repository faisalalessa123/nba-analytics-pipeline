9, which would skew per-game averages)\n","SEASONS = [\"2021-22\", \"2022-23\", \"2023-24\", \"2024-25\"]\n","\n","# Initialize empty lists to collect data across all seasons\n","all_player_traditional = []\n","all_player_advanced = []\n","all_team_stats = []\n","\n","# Helper function to handle request timeouts from NBA.com\n","# Retries up to 5 times with a 10-second wait between attempts\n","def fetch_with_retry(endpoint, retries=5, **kwargs):\n","    for attempt in range(retries):\n","        try:\n","            result = endpoint(timeout=60, **kwargs)\n","            return result.get_data_frames()[0]\n","        except Exception as e:\n","            print(f\"  Attempt {attempt+1} failed: {e}. Retrying in 10s...\")\n","            time.sleep(10)\n","    raise Exception(\"All retries failed.\")\n","\n","for season in SEASONS:\n","    print(f\"Fetching {season}...\")\n","\n","    # Pull basic per-game stats: points, assists, rebounds, FG%, 3P%, FT%, etc.\n","    df = fetch_with_retry(leaguedashplayerstats.LeagueDashPlayerStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Base\",\n","        per_mode_detailed=\"PerGame\",\n","    )\n","    df[\"SEASON\"] = season\n","    all_player_traditional.append(df)\n","    time.sleep(3)  # Pause to avoid being rate-limited by NBA.com\n","\n","    # Pull advanced metrics: PER, TS%, BPM, VORP, Win Shares, +/-, USG%, etc.\n","    df = fetch_with_retry(leaguedashplayerstats.LeagueDashPlayerStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Advanced\",\n","        per_mode_detailed=\"PerGame\",\n","    )\n","    df[\"SEASON\"] = season\n","    all_player_advanced.append(df)\n","    time.sleep(3)\n","\n","    # Pull team-level advanced stats: offensive/defensive/net rating, pace, etc.\n","    df = fetch_with_retry(leaguedashteamstats.LeagueDashTeamStats,\n","        season=season,\n","        measure_type_detailed_defense=\"Advanced\",\n","    )\n","    df[\"SEASON\"] = season\n","    all_team_stats.append(df)\n","    time.sleep(3)\n","\n","# Combine all seasons into single DataFrames and save as CSVs\n","pd.concat(all_player_traditional).to_csv(\"player_traditional.csv\", index=False)\n","pd.concat(all_player_advanced).to_csv(\"player_advanced.csv\", index=False)\n","pd.concat(all_team_stats).to_csv(\"team_stats.csv\", index=False)\n","\n","print(\"Done! 3 CSVs saved.\")"]},{"cell_type":"code","source":["# Check that each CSV file was created and has data (size in bytes)\n","\n","import os\n","print(\"player_traditional.csv:\", os.path.getsize(\"player_traditional.csv\"), \"bytes\")\n","print(\"player_advanced.csv:\", os.path.getsize(\"player_advanced.csv\"), \"bytes\")\n","print(\"team_stats.csv:\", os.path.getsize(\"team_stats.csv\"), \"bytes\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7akCL0XVibO4","executionInfo":{"status":"ok","timestamp":1775701844936,"user_tz":420,"elapsed":13,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"abeb0db9-5d56-463a-f950-d12e0616c2d0"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["player_traditional.csv: 672714 bytes\n","player_advanced.csv: 875176 bytes\n","team_stats.csv: 26946 bytes\n"]}]},{"cell_type":"code","source":["# Download all 3 CSVs to your local machine\n","# Note: allow popups in your browser if downloads don't start automatically\n","\n","from google.colab import files\n","files.download(\"player_traditional.csv\")\n","files.download(\"player_advanced.csv\")\n","files.download(\"team_stats.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":17},"id":"6Q0DkkhjfA7-","executionInfo":{"status":"ok","timestamp":1775701844957,"user_tz":420,"elapsed":19,"user":{"displayName":"Faisal Alessa","userId":"15182016480962682188"}},"outputId":"66a597c1-2842-45f0-86b6-d6d90211b805"},"execution_count":10,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.displa